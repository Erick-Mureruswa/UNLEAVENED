# Supabase (Dashboard > Project Settings > API)
# Leave unset to run from the local catalog in lib/products.ts.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# WhatsApp checkout number: international format, no "+", no spaces.
# Example for Zimbabwe: 263771234567
NEXT_PUBLIC_WHATSAPP_NUMBER=
